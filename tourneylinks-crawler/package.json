{
  "name": "tourneylinks-tournament-crawler",
  "version": "1.0.0",
  "description": "Nationwide golf tournament discovery agent — crawls, extracts, normalizes, and deduplicates tournament data from across the web",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "crawl": "tsx src/index.ts --run-cycle",
    "crawl:source": "tsx src/index.ts --source",
    "test": "vitest run",
    "lint": "eslint src/",
    "add-email": "tsx scripts/add-email-column.ts",
    "enrich-ny": "tsx scripts/enrich-ny-courses.ts"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "bullmq": "^5.20.0",
    "cheerio": "^1.0.0",
    "cron": "^3.1.0",
    "csv-parse": "^6.2.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "fuse.js": "^7.0.0",
    "ioredis": "^5.4.0",
    "node-fetch": "^3.3.0",
    "p-queue": "^8.0.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
